{
  "buildCommand": "npm run build && cp dist/client/index.html dist/client/404.html",
  "outputDirectory": "dist/client",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-src 'self' *.google.com;"
        }
      ]
    }
  ]
}

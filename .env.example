# No Firebase environment variables are required for the current deployment.
# This project can run as a normal static website without billing.
# Remove Firebase variables from Vercel if you don't want to use Firebase.

# If you choose to enable Firebase later, add these values manually:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

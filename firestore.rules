rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rule 1: Site Data (site/main)
    // This is the main document for your website's content.
    // Allow anyone to read it (public access for visitors).
    // Temporarily allowing anyone to write to it to fix the save issue.
    match /site/{document=**} {
      allow read: if true;
      allow write: if true; // WARNING: Insecure, allows anyone to modify your site data.
    }

    // Rule 2: Patients Collection
    // This is for the test "Patients" section in the admin panel.
    // Only authenticated users should be able to read or write here.
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }
  }
}
